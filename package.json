{
  "name": "packtrack",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "build": "npm run build -w shared && npm run build -w server && npm run build -w client",
    "dev:server": "npm run start:dev -w server",
    "dev:client": "npm run start -w client"
  }
}
